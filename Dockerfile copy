# ============================================================================
# ASML Micro-Learning Pipeline — Self-contained Docker image
# ============================================================================
# Runs entirely offline once built. No LM Studio, no HuggingFace at runtime.
#
# Build (CPU):  docker build -t asml-pipeline .
# Build (GPU):  docker build --build-arg USE_GPU=1 -t asml-pipeline-gpu .
# ============================================================================
FROM ubuntu:22.04 AS base

# Prevent interactive prompts during apt installs
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# --- System packages --------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3.11-venv \
    python3.11-dev \
    python3-pip \
    ffmpeg \
    git \
    curl \
    build-essential \
    cmake \
    && rm -rf /var/lib/apt/lists/*

# Make python3.11 the default
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1 \
    && update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1

# Upgrade pip
RUN python3 -m pip install --no-cache-dir --upgrade pip setuptools wheel

# --- GPU support (conditional) ----------------------------------------------
ARG USE_GPU=0

# If USE_GPU=1, install CUDA toolkit for llama-cpp-python GPU acceleration
# (The base image stays the same; we just add the CUDA build flags)
ENV CMAKE_ARGS=""
RUN if [ "$USE_GPU" = "1" ]; then \
        apt-get update && apt-get install -y --no-install-recommends \
            nvidia-cuda-toolkit \
        && rm -rf /var/lib/apt/lists/* \
        && echo "GPU build enabled"; \
    fi

# --- Python dependencies ----------------------------------------------------
WORKDIR /app

COPY requirements.txt /app/requirements.txt

# Install llama-cpp-python with or without GPU
RUN if [ "$USE_GPU" = "1" ]; then \
        CMAKE_ARGS="-DGGML_CUDA=on" pip install --no-cache-dir llama-cpp-python[server]; \
    else \
        pip install --no-cache-dir llama-cpp-python[server]; \
    fi

RUN pip install --no-cache-dir -r requirements.txt

# --- Copy pipeline scripts --------------------------------------------------
COPY scripts/ /app/scripts/
COPY docker/entrypoint.sh /app/entrypoint.sh
COPY docker/run_full_pipeline.sh /app/run_full_pipeline.sh
COPY docker/llm_server.py /app/llm_server.py

RUN chmod +x /app/entrypoint.sh /app/run_full_pipeline.sh

# --- Directory structure -----------------------------------------------------
# These get populated via volume mounts at runtime:
#   /app/Data/raw_videos       <- your .mp4 files
#   /app/models/llm            <- GGUF model file
#   /app/models/whisper        <- faster-whisper CT2 model directory
#   /app/models/embeddings     <- sentence-transformers model directory
RUN mkdir -p \
    /app/Data/raw_videos \
    /app/Data/processed/audio_wav \
    /app/Data/processed/subtitles \
    /app/Data/transcripts_raw \
    /app/Data/transcripts_clean \
    /app/Data/transcripts_structured \
    /app/Data/transcripts_aligned \
    /app/Data/transcripts_segmented \
    /app/Data/references \
    /app/Data/embeddings \
    /app/models/llm \
    /app/models/whisper \
    /app/models/embeddings \
    /app/logs

# --- Default environment variables -------------------------------------------
# These can be overridden in docker-compose.yml or at runtime
ENV LLM_MODEL_PATH="/app/models/llm/Nous-Hermes-2-Mistral-7B-DPO.Q4_0.gguf"
ENV LLM_PORT=1234
ENV LLM_HOST="127.0.0.1"
ENV LLM_CONTEXT_SIZE=4096
ENV WHISPER_MODEL_DIR="/app/models/whisper"
ENV WHISPER_DEVICE="cpu"
ENV WHISPER_COMPUTE_TYPE="int8"
ENV EMBEDDING_MODEL_DIR="/app/models/embeddings/all-MiniLM-L6-v2"
ENV GLOSSARY_CSV="/app/Data/ASML Glossary.csv"

EXPOSE 1234

ENTRYPOINT ["/app/entrypoint.sh"]
CMD ["pipeline"]
